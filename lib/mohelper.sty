\newcommand{\sliptogether}[6]{

    \pgfmathsetmacro{\xposleft}{\orbitallength /2 + (\orbitallength * #2 + \orbitaldistance * (#2 - 1)) /2}
    \pgfmathsetmacro{\xposmiddleleft}{(\orbitallength + \columndistance) +\orbitallength /2 - (\orbitallength * #4 + \orbitaldistance * (#4 - 1)) /2}
    \pgfmathsetmacro{\xposmiddleright}{(\orbitallength + \columndistance)  + + \orbitallength /2+ (\orbitallength * #4 + \orbitaldistance * (#4 - 1)) /2}
    \pgfmathsetmacro{\xposright}{(\orbitallength + \columndistance)*2 + \orbitallength /2 - (\orbitallength * #6 + \orbitaldistance * (#6 - 1)) /2}

    % \edef\tempcall{\noexpand\orbital{\xpos}{#1}{\name}{\spin}}
    % \tempcall
    \ifcase#2

    \else
        \draw[dashed, thin, gray] (\xposleft,#1) -- (\xposmiddleleft,#3);
    \fi
    \ifcase#6

    \else
        \draw[dashed, thin, gray] (\xposmiddleright,#3) -- (\xposright,#5);
    \fi

}
