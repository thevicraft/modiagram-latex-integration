        \StrBehind{##1}{/}[\tempSpin]%

        \pgfmathsetmacro{\ypos}{#1 - ((\orbit@ldistance) * (\arrlength - 1)) / 2 + (\currentIdx) * (\orbit@ldistance)}%

        \ifcase\currentIdx
        \else
            \def\tempName{}
        \fi

        \edef\tempcall{\noexpand\orbital{\xposs}{\ypos}{\tempName}{\tempSpin}}
