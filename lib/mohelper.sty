% Definition der Umgebung
\newenvironment{mohelper}[1][]{%
    % Code, der beim START ausgeführt wird (\begin{mohelper})
    \begin{tikzpicture}[#1] % Erlaubt zusätzliche TikZ-Optionen
        \initdiagram
        }{%
        % Code, der am ENDE ausgeführt wird (\end{mohelper})
    \end{tikzpicture}
}


\newcommand{\orbitallength}{0.8}
\newcommand{\orbitaldistance}{0.2}
\newcommand{\columndistance}{3}
\def\diagrammode{normal}
\def\electroncolor{black}

\newcommand{\initdiagram}{
    \xdef\minX{100}
    \xdef\maxX{-100}
    \xdef\minY{100}
    \xdef\maxY{-100}
}

\newcommand{\addlabel}[2]{
    \foreach \name [count=\i] in {#1}{
            \pgfmathsetmacro{\pos}{\orbitallength/2 + (\i - 1) * (\orbitallength + \columndistance)}
            \node[below=0pt, font=\scriptsize] at (\pos,\minY-0.5-#2) {\name};
        }
}
\newcommand{\addenergyscale}[1]{
\draw[->, -{Stealth[scale=1.2]}, semithick] (\minX-0.5-#1,\minY-0.5) -- (\minX-0.5-#1,\maxY+0.5) node[anchor=east, font=\footnotesize] {E};
}

\newcommand{\showenergydifference}[4]{
\StrBefore{#1}{,}[\orbup]%
\StrBehind{#1}{,}[\orbdown]%
\ifstrequal{#2}{left}{\pgfmathsetmacro{\xpos}{\orbitallength/2 + #3}}{}
\ifstrequal{#2}{middle}{\pgfmathsetmacro{\xpos}{\orbitallength/2 + #3 + \orbitallength + \columndistance}}{}
\ifstrequal{#2}{right}{\pgfmathsetmacro{\xpos}{\orbitallength/2 + #3 + 2 * (\orbitallength + \columndistance)}}{}
\draw[<->, red, {Stealth[scale=0.7]}-{Stealth[scale=0.7]}, semithick] (\xpos,\orbdown) -- (\xpos,\orbup) node[midway, right, font=\footnotesize] {#4};
}

% 1. Ein Befehl für ein einzelnes Orbital (eine Linie)
% Syntax: \orbital(x,y){label}
\newcommand{\orbital}[4]{
    \draw[thick] (#1,#2) -- (#1+\orbitallength,#2);% node[below, font=\scriptsize] {#3};
    \ifstrequal{#4}{up}{\electronup{#1}{#2}}{}
    \ifstrequal{#4}{down}{\electrondown{#1}{#2}}{}
    \ifstrequal{#4}{pair}{\electronup{#1}{#2}\electrondown{#1}{#2}}{}

    \ifdefstring{\diagrammode}{compact}{
        \edef\labeldistance{3pt}
    }{
        \edef\labeldistance{7pt}
    }

    \node[below=\labeldistance, font=\scriptsize] at (#1+\orbitallength/2,#2) {#3};


    % \pgfmathsetmacro{\minX}{min(\minX, #1)}%
    % \pgfmathsetmacro{\maxX}{max(\maxX, \maxX + \orbitallength /2)}%
    % \pgfmathsetmacro{\minY}{min(\minY, #2)}%
    % \pgfmathsetmacro{\maxY}{max(\maxY, #2)}%

    \pgfmathsetmacro{\tempMinX}{min(\minX, #1)}
    \pgfmathsetmacro{\tempMaxX}{max(\maxX, #1 + \orbitallength)} % Hier die volle Breite nehmen!
    \pgfmathsetmacro{\tempMinY}{min(\minY, #2)}
    \pgfmathsetmacro{\tempMaxY}{max(\maxY, #2)}

    \xdef\minX{\tempMinX}
    \xdef\maxX{\tempMaxX}
    \xdef\minY{\tempMinY}
    \xdef\maxY{\tempMaxY}
}

% 2. Ein Befehl für Verbindungslinien (gestrichelt)
% Syntax: \connect(x1,y1)(x2,y2)
\newcommand{\drawconnection}[4]{
    \draw[dashed, thin, gray] (#1+\orbitallength,#2) -- (#3,#4);
}

\tikzset{
electronnormal/.style={\electroncolor, -{Stealth[harpoon]}, thick, semithick},
electroncompact/.style={\electroncolor, very thin, ->, very thin}
}

\newcommand{\getelecspecs}{
    \ifdefstring{\diagrammode}{compact}{
        \pgfmathsetmacro{\electronlength}{\orbitaldistance * 0.5}
        % \edef\electroncolor{red}
        \edef\elecstyle{electroncompact}
    }{
        \edef\electronlength{0.3}
        % \edef\eleccolor{black}
        \edef\elecstyle{electronnormal}
    }
}

% 3. Ein Befehl für Elektronen (Pfeile)
% Syntax: \electronup(x,y)
\newcommand{\electronup}[2]{
    \getelecspecs
    \draw[\elecstyle] (#1+0.3,#2-\electronlength) -- (#1+0.3,#2+\electronlength);
}
\newcommand{\electrondown}[2]{
    \getelecspecs
    \draw[\elecstyle] (#1+0.5,#2+\electronlength) -- (#1+0.5,#2-\electronlength);
}




% hier die ganzes utils für a,e,t
% param: 
% 1: y-level
% 2: name des orbitals
% 3: zugehörigkeit: left right middle
\newcommand{\nondegenerate}[4]{
    % \newcommand{\xposition}{
    \ifstrequal{#3}{left}{\def\xpos{0}}{}
    \ifstrequal{#3}{middle}{\def\xpos{\orbitallength+\columndistance}}{}
    \ifstrequal{#3}{right}{\def\xpos{\orbitallength*2+\columndistance*2}}{}
    % }
    \orbital{\xpos}{#1}{#2}{#4}
}

\newcommand{\twicedegenerate}[6]{
    % \newcommand{\xposition}{
    \ifstrequal{#4}{left}{\def\xposs{0}}{}
    \ifstrequal{#4}{middle}{\def\xposs{\orbitallength+\columndistance}}{}
    \ifstrequal{#4}{right}{\def\xposs{\orbitallength*2+\columndistance*2}}{}
    % }
    \def\xpos{\xposs-\orbitallength/2-\orbitaldistance/2}
    \orbital{\xpos}{#1}{#2}{#5}
    \orbital{\xpos+\orbitallength+\orbitaldistance}{#1}{#3}{#6}
}

\newcommand{\tripledegenerate}[8]{
    % \newcommand{\xposition}{
    \ifstrequal{#5}{left}{\def\xposs{0}}{}
    \ifstrequal{#5}{middle}{\def\xposs{\orbitallength+\columndistance}}{}
    \ifstrequal{#5}{right}{\def\xposs{\orbitallength*2+\columndistance*2}}{}
    % }
    \def\xpos{\xposs-\orbitallength-\orbitaldistance}
    \orbital{\xpos}{#1}{#2}{#6}
    \orbital{\xpos+\orbitallength+\orbitaldistance}{#1}{#3}{#7}
    \orbital{\xpos+2*\orbitallength+2*\orbitaldistance}{#1}{#4}{#8}

}

