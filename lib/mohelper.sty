\DeclareListParser{\myCSVsplitter}{,}
% NUR normaler modus
\newcommand{\degeneratecorrected}[3]{%
    % 1. Anzahl für Zentrierung berechnen
    \StrCount{#2}{,}[\arrcount]%
    \pgfmathsetmacro{\arrlength}{int(\arrcount + 1)}%

    % 2. X-Basis bestimmen
    \ifstrequal{#3}{left}{\def\xposs{0}}{}%
    \ifstrequal{#3}{middle}{\def\xposs{\orbitallength+\columndistance}}{}%
    \ifstrequal{#3}{right}{\def\xposs{\orbitallength*2+\columndistance*2}}{}%

    % 3. Der "Text-Splitter" von etoolbox
    % Wir definieren eine Zählvariable für die Position
    \def\currentIdx{0}%

    % Dieser Befehl geht durch JEDES Element einer Komma-Liste, 
    % egal ob sie als Text oder Makro kommt.
    % \DeclareListParser{\myCSVsplitter}{,}%
    \renewcommand*{\do}[1]{% 
        % #1 ist jetzt z.B. "v/pair"
        % Wir spalten den Schrägstrich mit xstring
        \StrBefore{##1}{/}[\tempName]%
        \StrBehind{##1}{/}[\tempSpin]%

        % X-Position berechnen
        \pgfmathsetmacro{\xpos}{\xposs - ((\orbitallength + \orbitaldistance) * (\arrlength - 1)) / 2 + (\currentIdx) * (\orbitallength + \orbitaldistance)}%

        % Orbital zeichnen
        % \orbital{\xpos}{#1}{\tempName}{\tempSpin}%
        \edef\tempcall{\noexpand\orbital{\xpos}{#1}{\tempName}{\tempSpin}}
        \tempcall

        % Index erhöhen
        \pgfmathsetmacro{\nextIdx}{int(\currentIdx + 1)}%
        \xdef\currentIdx{\nextIdx}%
    }%

    % JETZT der Aufruf, der den Text endlich aufbricht:
    \expandafter\docsvlist\expandafter{#2}%
}
% NUR kompakter modus
\newcommand{\degeneratecorrectedcompact}[3]{%
    % 1. Anzahl für Zentrierung berechnen
    \StrCount{#2}{,}[\arrcount]%
    \pgfmathsetmacro{\arrlength}{int(\arrcount + 1)}%

    % 2. X-Basis bestimmen
    \ifstrequal{#3}{left}{\def\xposs{0}}{}%
    \ifstrequal{#3}{middle}{\def\xposs{\orbitallength+\columndistance}}{}%
    \ifstrequal{#3}{right}{\def\xposs{\orbitallength*2+\columndistance*2}}{}%

    % 3. Der "Text-Splitter" von etoolbox
    % Wir definieren eine Zählvariable für die Position
    \def\currentIdx{0}%

    % Dieser Befehl geht durch JEDES Element einer Komma-Liste, 
    % egal ob sie als Text oder Makro kommt.
    % \DeclareListParser{\myCSVsplitter}{,}%
    \renewcommand*{\do}[1]{% 
        % #1 ist jetzt z.B. "v/pair"
        % Wir spalten den Schrägstrich mit xstring
        \StrBefore{##1}{/}[\tempName]%
        \StrBehind{##1}{/}[\tempSpin]%

        % X-Position berechnen
        \pgfmathsetmacro{\ypos}{#1 - ((\orbitaldistance) * (\arrlength - 1)) / 2 + (\currentIdx) * (\orbitaldistance)}%

        \ifcase\currentIdx
        \else
            \def\tempName{}
        \fi

        % Orbital zeichnen
        % \orbital{\xpos}{#1}{\tempName}{\tempSpin}%
        \edef\tempcall{\noexpand\orbital{\xposs}{\ypos}{\tempName}{\tempSpin}}
        \tempcall

        % Index erhöhen
        \pgfmathsetmacro{\nextIdx}{int(\currentIdx + 1)}%
        \xdef\currentIdx{\nextIdx}%
    }%

    % JETZT der Aufruf, der den Text endlich aufbricht:
    \expandafter\docsvlist\expandafter{#2}%
}

\newcommand{\connecttriple}[1]{
    \foreach \a/\b/\c/\d/\e/\f [count=\i] in {#1}{



            \pgfmathsetmacro{\xposleft}{\orbitallength /2 + (\orbitallength * \b + \orbitaldistance * (\b - 1)) /2}
            \pgfmathsetmacro{\xposmiddleleft}{(\orbitallength + \columndistance) +\orbitallength /2 - (\orbitallength * \d + \orbitaldistance * (\d - 1)) /2}
            \pgfmathsetmacro{\xposmiddleright}{(\orbitallength + \columndistance)  + + \orbitallength /2+ (\orbitallength * \d + \orbitaldistance * (\d - 1)) /2}
            \pgfmathsetmacro{\xposright}{(\orbitallength + \columndistance)*2 + \orbitallength /2 - (\orbitallength * \f + \orbitaldistance * (\f - 1)) /2}

            % \edef\tempcall{\noexpand\orbital{\xpos}{#1}{\name}{\spin}}
            % \tempcall
            \ifcase\b

            \else
                \draw[dashed, thin, gray] (\xposleft,\a) -- (\xposmiddleleft,\c);
            \fi
            \ifcase\f

            \else
                \draw[dashed, thin, gray] (\xposmiddleright,\c) -- (\xposright,\e);
            \fi
        }
}

